rules_version = '2';
// Firebase Storage is not used by this app (Spark free plan).
// Voice notes are base64-encoded inside Firestore documents.
// This file is kept as a placeholder in case the project is upgraded to Blaze later.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
