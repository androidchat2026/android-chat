rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Voice notes: sender can upload to recipient's folder; recipient can read/delete
    match /voice_notes/{recipientId}/{fileName} {
      allow write: if request.auth != null;
      allow read, delete: if request.auth != null
                          && request.auth.uid == recipientId;
    }
  }
}
