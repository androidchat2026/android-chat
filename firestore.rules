rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile; others can read (for search)
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Messages: sender can create; recipient can read and update (mark consumed)
    match /messages/{messageId} {
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.senderId;
      allow read:   if request.auth != null
                    && (request.auth.uid == resource.data.senderId
                        || request.auth.uid == resource.data.recipientId);
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.recipientId
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['consumed', 'consumedAt', 'status', 'voiceBase64']);
      allow delete: if false; // cleanup done server-side by GitHub Actions
    }
  }
}
